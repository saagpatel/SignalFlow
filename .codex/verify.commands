# codex-os-managed
pnpm git:guard:all
pnpm lint
pnpm typecheck
pnpm test -- --run
pnpm test:coverage
pnpm build
pnpm docs:check
cd src-tauri && cargo test
cd src-tauri && cargo fmt -- --check
cd src-tauri && cargo clippy -- -D warnings
