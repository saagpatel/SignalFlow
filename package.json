{
  "name": "signalflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lean": "./scripts/lean-dev.sh",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src vite.config.ts vitest.config.ts eslint.config.mjs",
    "lint:fix": "eslint src vite.config.ts vitest.config.ts eslint.config.mjs --fix",
    "preview": "vite preview",
    "tauri": "tauri",
    "clean:heavy": "./scripts/clean-heavy.sh",
    "clean:all": "./scripts/clean-all-local.sh",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled true --coverage.provider=v8 --coverage.reporter=lcov --coverage.reporter=text",
    "test:watch": "vitest",
    "prepare": "husky",
    "commit": "cz",
    "commitlint": "commitlint",
    "git:guard:branch": "bash scripts/git/guard-branch.sh",
    "git:guard:no-main-push": "bash scripts/git/guard-no-main-push.sh",
    "git:guard:atomic": "bash scripts/git/guard-atomic.sh",
    "git:guard:generated": "bash scripts/git/guard-generated.sh",
    "git:guard:large-files": "bash scripts/git/guard-large-files.sh",
    "git:guard:secrets": "bash scripts/git/guard-secrets.sh",
    "git:guard:all": "pnpm git:guard:branch && pnpm git:guard:atomic && pnpm git:guard:generated && pnpm git:guard:large-files && pnpm git:guard:secrets",
    "git:commit:propose": "node scripts/git/propose-commit-message.mjs",
    "git:session:save": "bash scripts/git/session-save.sh",
    "git:session:resume": "bash scripts/git/session-resume.sh",
    "pr:notes": "bash scripts/git/generate-pr-notes.sh",
    "perf:bundle": "node scripts/perf/bundle-report.mjs",
    "perf:build": "node scripts/perf/measure-build-time.mjs",
    "perf:assets": "bash scripts/perf/check-assets.sh",
    "perf:memory": "node --expose-gc scripts/perf/memory-smoke.mjs",
    "perf:baseline": "node scripts/perf/capture-baselines.mjs",
    "perf:summary": "node scripts/perf/summarize.mjs",
    "docs:check": "node scripts/docs/check-doc-artifacts.mjs",
    "release:pack-macos-app": "tar -C src-tauri/target/release/bundle/macos -czf src-tauri/target/release/bundle/macos/SignalFlow.app.tar.gz SignalFlow.app",
    "release:checksum": "shasum -a 256 src-tauri/target/release/bundle/dmg/*.dmg src-tauri/target/release/bundle/macos/*.tar.gz > src-tauri/target/release/bundle/dmg/SHA256SUMS.txt",
    "release:notes": "node scripts/release/generate-release-notes.mjs",
    "release:validate-macos": "bash scripts/release/validate-macos-artifacts.sh",
    "release:validate-signed-macos": "bash scripts/release/validate-signed-macos-distribution.sh",
    "verify": "bash .codex/scripts/run_verify_commands.sh",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@xyflow/react": "^12.10.0",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.563.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zundo": "^2.3.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/cz-commitlint": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "commitizen": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.0.4",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
